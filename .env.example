# Copy to .env (or just run ./setup.sh, which generates .env for you).

# Official upstream stack + local override (VPN-only binding).
# The built-in backup service is disabled for this evaluation setup.
COMPOSE_FILE=zammad-docker-compose/docker-compose.yml:zammad-docker-compose/scenarios/disable-backup-service.yml:docker-compose.override.yml
COMPOSE_PROJECT_NAME=zammad

# Publish the web UI on this address only — your VPN interface address.
# With Tailscale: `tailscale ip -4`
BIND_IP=100.x.y.z
ZAMMAD_UI_PORT=8081

# Seeded into Zammad on FIRST boot only (Settings fqdn / http_type).
# Use the exact host:port you will type into the browser —
# with Tailscale, the MagicDNS name (e.g. myhost.tailXXXX.ts.net).
ZAMMAD_FQDN=myhost.tailXXXX.ts.net:8081
ZAMMAD_HTTP_TYPE=http

TZ=UTC
POSTGRES_PASS=change-me-random-hex
